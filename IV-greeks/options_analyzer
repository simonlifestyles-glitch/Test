def print_report(df: pd.DataFrame, S: float, hv: float, symbol: str):
    print(f"\n{'=' * 70}")
    print(f"  {symbol}  Options Analysis Report")
    print(f"{'=' * 70}")
    print(f"  現價 (Current Price) : {S:.2f}")
    print(f"  30日歷史波動率 (HV)  : {hv*100:.2f}%" if hv else "  HV : N/A")
    print(f"  總合約數             : {len(df):,}")
    print(f"  到期日數量           : {df['expiration'].nunique()}")
    print(f"{'─' * 70}")

    # 每個到期日印出 ATM 附近的合約
    for exp in sorted(df['expiration'].unique()):
        df_exp = df[df['expiration'] == exp].copy()
        days   = df_exp['days_to_exp'].iloc[0]

        # ATM = 最接近現價的 Strike
        strikes = df_exp['strike'].unique()
        atm     = strikes[np.argmin(np.abs(strikes - S))]

        df_atm  = df_exp[df_exp['strike'] == atm].sort_values('type')

        print(f"\n  到期日: {exp}  ({days}天後)")
        print(f"  ATM 履約價: {atm}")
        print(f"  {'Type':<6} {'Strike':>8} {'Mkt Price':>10} {'Theo':>8} "
              f"{'IV%':>7} {'IV-HV':>7} {'Delta':>7} {'Gamma':>8} "
              f"{'Theta':>7} {'Vega':>7} {'Rho':>7}")
        print(f"  {'-'*96}")

        for _, r_row in df_atm.iterrows():
            iv_hv = f"{r_row['IV_HV_diff']:+.2f}" if r_row['IV_HV_diff'] is not None else "  N/A"
            print(f"  {r_row['type']:<6} {r_row['strike']:>8.1f} "
                  f"{r_row['market_price']:>10.4f} {r_row['theo_price']:>8.4f} "
                  f"{r_row['IV']:>6.2f}% {iv_hv:>7} "
                  f"{r_row['delta']:>7.4f} {r_row['gamma']:>8.6f} "
                  f"{r_row['theta']:>7.4f} {r_row['vega']:>7.4f} {r_row['rho']:>7.4f}")

    print(f"\n{'=' * 70}\n")



# ═══════════════════════════════════════════
# 選擇到期日（互動式，最多3個）
# ═══════════════════════════════════════════

def pick_expirations(all_exps: list, max_pick: int = 3) -> list:
    """
    列出所有到期日讓使用者選擇最多 3 個，
    若直接按 Enter 則自動選前 3 個。
    """
    print(f"\n  可用到期日（共 {len(all_exps)} 個）：")
    for i, exp in enumerate(all_exps):
        print(f"    [{i+1:>2}] {exp}")

    print(f"\n  請輸入最多 {max_pick} 個編號，用逗號分隔")
    print(f"  （直接按 Enter 自動選前 {max_pick} 個）")
    raw = input("  你的選擇：").strip()

    if not raw:
        chosen = all_exps[:max_pick]
        print(f"  自動選取：{chosen}")
        return chosen

    try:
        indices = [int(x.strip()) - 1 for x in raw.split(',')]
        indices = [i for i in indices if 0 <= i < len(all_exps)][:max_pick]
        chosen  = [all_exps[i] for i in indices]
        print(f"  已選取：{chosen}")
        return chosen
    except ValueError:
        print("  輸入有誤，自動選取前 3 個。")
        return all_exps[:max_pick]


# ═══════════════════════════════════════════
# 圖表
# ═══════════════════════════════════════════

def plot_report(df: pd.DataFrame, S: float, hv: float, symbol: str):

    all_exps    = sorted(df['expiration'].unique())
    greek_exps  = pick_expirations(all_exps, max_pick=3)

    # IV Smile / Term Structure 用全部到期日
    colors = plt.cm.tab10.colors

    # ── 圖1 + 圖2：IV（上排）──────────────────
    fig1, axes1 = plt.subplots(1, 2, figsize=(16, 5))
    fig1.suptitle(f"{symbol}  IV Analysis  |  Price: {S:.2f}",
                  fontsize=13, fontweight='bold')

    # 圖1：IV Smile（全部到期日，最多顯示 12 條）
    ax = axes1[0]
    smile_exps = all_exps[:12]
    for i, exp in enumerate(smile_exps):
        sub = df[(df['expiration'] == exp) & (df['type'] == 'call')]
        ax.plot(sub['strike'], sub['IV'], marker='o', ms=2.5,
                label=exp[5:], color=colors[i % 10], alpha=0.8)
    if hv:
        ax.axhline(hv * 100, color='black', linestyle='--', lw=1.5,
                   label=f'HV30: {hv*100:.1f}%')
    ax.axvline(S, color='gold', lw=2, linestyle='-', label=f'Price: {S:.1f}')
    ax.set_title('IV Smile — Call (All Expirations)')
    ax.set_xlabel('Strike')
    ax.set_ylabel('IV (%)')
    ax.legend(fontsize=6, ncol=2)
    ax.grid(True, alpha=0.3)

    # 圖2：IV Term Structure（全部到期日）
    ax = axes1[1]
    atm_iv_call, atm_iv_put, exp_labels, days_list = [], [], [], []
    hv_val = hv * 100 if hv else None

    for exp in all_exps:
        sub_exp = df[df['expiration'] == exp]
        strikes = sub_exp['strike'].unique()
        atm     = strikes[np.argmin(np.abs(strikes - S))]
        c_iv = sub_exp[(sub_exp['type'] == 'call') & (sub_exp['strike'] == atm)]['IV']
        p_iv = sub_exp[(sub_exp['type'] == 'put')  & (sub_exp['strike'] == atm)]['IV']
        atm_iv_call.append(c_iv.values[0] if len(c_iv) > 0 else np.nan)
        atm_iv_put.append( p_iv.values[0] if len(p_iv) > 0 else np.nan)
        exp_labels.append(exp)
        days_list.append(sub_exp['days_to_exp'].iloc[0])

    x_idx = list(range(len(exp_labels)))

    ax.plot(x_idx, atm_iv_call, marker='o', ms=5, label='Call ATM IV',
            color='steelblue', lw=1.5)
    ax.plot(x_idx, atm_iv_put,  marker='s', ms=5, label='Put ATM IV',
            color='tomato', lw=1.5)

    # 標示異常偏高（超過 HV 的 1.5 倍）
    if hv_val:
        threshold = hv_val * 1.5
        ax.axhline(hv_val,   color='black',  linestyle='--', lw=1.5,
                   label=f'HV30: {hv_val:.1f}%')
        ax.axhline(threshold, color='orange', linestyle=':', lw=1.5,
                   label=f'Abnormal threshold: {threshold:.1f}%')
        for i, (cv, pv) in enumerate(zip(atm_iv_call, atm_iv_put)):
            if not np.isnan(cv) and cv > threshold:
                ax.annotate(f'High IV!\n{exp_labels[i][5:]}',
                            xy=(i, cv), xytext=(i + 0.3, cv + 1),
                            fontsize=7, color='red',
                            arrowprops=dict(arrowstyle='->', color='red', lw=1))
            if not np.isnan(pv) and pv > threshold:
                ax.annotate(f'High IV!\n{exp_labels[i][5:]}',
                            xy=(i, pv), xytext=(i + 0.3, pv + 1),
                            fontsize=7, color='darkred',
                            arrowprops=dict(arrowstyle='->', color='darkred', lw=1))

    ax.set_xticks(x_idx)
    ax.set_xticklabels([f"{e[5:]}\n({d}d)" for e, d in zip(exp_labels, days_list)],
                       fontsize=6, rotation=45)
    ax.set_title('IV Term Structure — ATM (All Expirations)\n'
                 'Orange dotted = 1.5x HV30 (Abnormal threshold)')
    ax.set_xlabel('Expiration (days to expiry)')
    ax.set_ylabel('IV (%)')
    ax.legend(fontsize=8)
    ax.grid(True, alpha=0.3)

    plt.tight_layout()
    f1name = f"{symbol}_IV_analysis.png"
    plt.savefig(f1name, dpi=150, bbox_inches='tight')
    print(f"\n  IV 圖表已儲存至 {f1name}")
    plt.show()

    # ── 圖3~6：Greeks（選定的最多3個到期日）────
    fig2, axes2 = plt.subplots(2, 2, figsize=(16, 10))
    fig2.suptitle(
        f"{symbol}  Greeks vs Strike  |  Price: {S:.2f}\n"
        f"Expirations: {', '.join(greek_exps)}",
        fontsize=13, fontweight='bold'
    )

    greek_colors = ['steelblue', 'tomato', 'seagreen']
    greek_list   = [
        ('delta', 'Delta', axes2[0, 0]),
        ('gamma', 'Gamma', axes2[0, 1]),
        ('theta', 'Theta (per day)', axes2[1, 0]),
        ('vega',  'Vega',  axes2[1, 1]),
    ]

    for col, ylabel, ax in greek_list:
        for j, exp in enumerate(greek_exps):
            sub_c = df[(df['expiration'] == exp) & (df['type'] == 'call')]
            sub_p = df[(df['expiration'] == exp) & (df['type'] == 'put')]
            days  = df[df['expiration'] == exp]['days_to_exp'].iloc[0]
            lbl   = f"{exp[5:]} ({days}d)"
            c     = greek_colors[j % 3]

            ax.plot(sub_c['strike'], sub_c[col], marker='o', ms=3,
                    label=f'Call {lbl}', color=c, lw=1.5)
            ax.plot(sub_p['strike'], sub_p[col], marker='s', ms=3,
                    label=f'Put {lbl}',  color=c, lw=1.5, linestyle='--')

        ax.axvline(S, color='gold', lw=2, linestyle='-', label=f'Price: {S:.1f}')
        if col in ('delta', 'theta'):
            ax.axhline(0, color='gray', lw=0.8, linestyle='--')
        ax.set_title(f'{ylabel} vs Strike')
        ax.set_xlabel('Strike')
        ax.set_ylabel(ylabel)
        ax.legend(fontsize=7)
        ax.grid(True, alpha=0.3)

    plt.tight_layout()
    f2name = f"{symbol}_Greeks_analysis.png"
    plt.savefig(f2name, dpi=150, bbox_inches='tight')
    print(f"  Greeks 圖表已儲存至 {f2name}")
    plt.show()


