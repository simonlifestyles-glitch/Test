# ═══════════════════════════════════════════
# BSM Fallback（當 py_vollib 未安裝時使用）
# ═══════════════════════════════════════════

def _d1(S, K, t, r, sigma):
    return (np.log(S / K) + (r + 0.5 * sigma**2) * t) / (sigma * np.sqrt(t))

def _d2(S, K, t, r, sigma):
    return _d1(S, K, t, r, sigma) - sigma * np.sqrt(t)

def bsm_price(flag, S, K, t, r, sigma):
    d1 = _d1(S, K, t, r, sigma)
    d2 = _d2(S, K, t, r, sigma)
    if flag == 'c':
        return S * norm.cdf(d1) - K * np.exp(-r * t) * norm.cdf(d2)
    else:
        return K * np.exp(-r * t) * norm.cdf(-d2) - S * norm.cdf(-d1)

def bsm_iv(market_price, S, K, t, r, flag, tol=1e-6, max_iter=200):
    lo, hi = 1e-6, 10.0
    for _ in range(max_iter):
        mid = (lo + hi) / 2
        p   = bsm_price(flag, S, K, t, r, mid)
        if abs(p - market_price) < tol:
            return mid
        if p < market_price:
            lo = mid
        else:
            hi = mid
    return (lo + hi) / 2

def bsm_greeks(flag, S, K, t, r, sigma):
    d1 = _d1(S, K, t, r, sigma)
    d2 = _d2(S, K, t, r, sigma)
    sign = 1 if flag == 'c' else -1
    delta_ = sign * norm.cdf(sign * d1)
    gamma_ = norm.pdf(d1) / (S * sigma * np.sqrt(t))
    theta_ = (-(S * norm.pdf(d1) * sigma) / (2 * np.sqrt(t))
              - sign * r * K * np.exp(-r * t) * norm.cdf(sign * d2)) / 365
    vega_  = S * norm.pdf(d1) * np.sqrt(t) / 100
    rho_   = sign * K * t * np.exp(-r * t) * norm.cdf(sign * d2) / 100
    return delta_, gamma_, theta_, vega_, rho_


# ═══════════════════════════════════════════
# 計算 HV（歷史波動率）
# ═══════════════════════════════════════════

def calc_hv(symbol: str, window: int = 30) -> float:
    hist = yf.download(symbol, period='90d', progress=False)
    if hist.empty:
        return None
    closes = hist['Close'].squeeze()
    log_returns = np.log(closes / closes.shift(1)).dropna()
    hv = log_returns.rolling(window).std().iloc[-1] * np.sqrt(252)
    return float(hv)


# ═══════════════════════════════════════════
# 主分析函式
# ═══════════════════════════════════════════

def analyze_options(symbol: str, r: float = 0.05):
    """
    symbol : 股票代碼
    r      : 無風險利率（預設 5%）
    """
    symbol = symbol.upper().strip()
    tk     = yf.Ticker(symbol)

    # 現價
    try:
        S = float(tk.fast_info['last_price'])
    except Exception:
        print(f"無法取得 {symbol} 現價，請確認代碼。")
        return None

    # 所有到期日
    expirations = tk.options
    if not expirations:
        print(f"找不到 {symbol} 的選擇權資料。")
        return None

    # HV
    hv = calc_hv(symbol)

    today = date.today()
    rows  = []

    print(f"\n正在處理 {len(expirations)} 個到期日，請稍候...")

    for exp_date in expirations:
        # 到期日距今天數
        exp_dt = datetime.strptime(exp_date, '%Y-%m-%d').date()
        days   = (exp_dt - today).days
        if days <= 0:
            continue
        t = days / 365.0

        chain = tk.option_chain(exp_date)

        for opt_type, df_chain in [('call', chain.calls), ('put', chain.puts)]:
            flag = 'c' if opt_type == 'call' else 'p'

            for _, row in df_chain.iterrows():
                K           = float(row['strike'])
                mkt_price   = float(row.get('lastPrice', 0) or 0)
                mkt_iv      = float(row.get('impliedVolatility', 0) or 0)

                # 跳過沒有報價的合約
                if mkt_price <= 0 or K <= 0:
                    continue

                # IV（優先用市場報的 IV，若為 0 則用 py_vollib 反推）
                iv = mkt_iv
                if iv <= 0 or iv > 5:
                    try:
                        if VOLLIB:
                            iv = calc_iv(mkt_price, S, K, t, r, flag)
                        else:
                            iv = bsm_iv(mkt_price, S, K, t, r, flag)
                    except Exception:
                        iv = None

                if not iv or iv <= 0:
                    continue

                # Greeks
                try:
                    if VOLLIB:
                        d = calc_delta(flag, S, K, t, r, iv)
                        g = calc_gamma(flag, S, K, t, r, iv)
                        th = calc_theta(flag, S, K, t, r, iv)
                        v = calc_vega(flag, S, K, t, r, iv)
                        rh = calc_rho(flag, S, K, t, r, iv)
                    else:
                        d, g, th, v, rh = bsm_greeks(flag, S, K, t, r, iv)
                except Exception:
                    continue

                # 理論價格（BSM）
                try:
                    theo_price = bsm_price(flag, S, K, t, r, iv)
                except Exception:
                    theo_price = None

                rows.append({
                    'expiration'  : exp_date,
                    'days_to_exp' : days,
                    'type'        : opt_type,
                    'strike'      : K,
                    'market_price': round(mkt_price, 4),
                    'theo_price'  : round(theo_price, 4) if theo_price else None,
                    'IV'          : round(iv * 100, 2),        # 以 % 顯示
                    'HV_30'       : round(hv * 100, 2) if hv else None,
                    'IV_HV_diff'  : round((iv - hv) * 100, 2) if hv else None,
                    'delta'       : round(d, 4),
                    'gamma'       : round(g, 6),
                    'theta'       : round(th, 4),
                    'vega'        : round(v, 4),
                    'rho'         : round(rh, 4),
                })

    if not rows:
        print("無法取得有效選擇權資料。")
        return None

    df = pd.DataFrame(rows)
    return df, S, hv, symbol


